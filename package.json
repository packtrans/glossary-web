{
  "name": "packtrans-glossary-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc -b && vp build",
    "deploy": "vp build && vp exec wrangler deploy",
    "lint": "vp lint .",
    "preview": "vp preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@packtrans/glossary": "0.0.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-wasm": "^3.5.0",
    "vite-plus": "latest",
    "wrangler": "^4.103.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.0.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
