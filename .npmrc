# GitHub Packages auth for @packtrans/* (see pnpm-workspace.yaml for registry URL).
# pnpm v11 does not expand ${...} in a committed .npmrc unless you opt in:
#   export PNPM_CONFIG_NPMRC_AUTH_FILE=.npmrc
# Or set the token directly:
#   export "pnpm_config_//npm.pkg.github.com/:_authToken=$GITHUB_NPM_AUTH_TOKEN"
//npm.pkg.github.com/:_authToken=${GITHUB_NPM_AUTH_TOKEN}
